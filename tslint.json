{
  "extends": [
    "tslint:latest",
    "tslint-react",
    "tslint-eslint-rules",
    "tslint-config-prettier"
  ],
  "linterOptions": {
    "exclude": ["node_modules/**/*.ts", "typings/**/*d.ts"]
  },
  "rules": {
    "member-access": false,
    "semicolon": [true, "never"],
    "no-implicit-dependencies": false,
    "object-literal-sort-keys": false,
    "interface-name": [true, "never-prefix"],
    "no-submodule-imports": false
  }
}
